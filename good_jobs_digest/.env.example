OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:14b-q4_K_M
OLLAMA_NUM_PREDICT=512
# Parallel scoring: workers = concurrent Ollama requests; batch_size = jobs per request
OLLAMA_SCORE_WORKERS=2
# Keep batch small (4) unless num_predict is high — avoids truncated batch JSON
OLLAMA_SCORE_BATCH_SIZE=4
OLLAMA_DESC_TRUNCATE=2000
OLLAMA_MISSION_BATCH_SIZE=8
OLLAMA_MISSION_WORKERS=2
# Auto-approve curated employers at or above this mission_score (liberal default: 50)
MISSION_APPROVE_MIN_SCORE=50
REGISTRY_LLM_FILTER=true
OLLAMA_KEEP_ALIVE=30m
# Digest: 0 = all scored jobs; raise (e.g. 65) to drop low combined scores from email
MIN_COMBINED_SCORE=0
DIGEST_TOP_N=50
# Fallback when profile/preferences.yaml has no digest.remote_only (prefer setting it there)
DIGEST_REMOTE_ONLY=true
SCORE_MAX_PER_RUN=0
# Only score jobs posted (or first seen by us) within N days; 0 = disabled
SCORE_MAX_AGE_DAYS=30
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=
SQLITE_PATH=data/jobs.db
PROFILE_PATH=profile/profile.md
PREFERENCES_PATH=profile/preferences.yaml
# Curated ATS: parallel polls (--limit N on ingest caps companies for testing)
INGEST_WORKERS=10
INGEST_DELAY_MS=150
SMARTRECRUITERS_API_KEY=
# Title gate before fetching job details / LLM (substring match, longest phrases first in list)
TARGET_ROLE_KEYWORDS=artificial intelligence engineer,analytics engineer,analytics engineering,ai engineer,machine learning engineer,ml engineer,data engineer,data engineering,data integration,data integrations,data platform engineer,etl engineer
EXCLUDE_TITLE_KEYWORDS=intern,internship
# BigQuery (raw API payloads, normalized mirror for LLM, score events)
BQ_ENABLED=true
BQ_PROJECT_ID=your-gcp-project-id
BQ_DATASET_ID=good_jobs_digest
BQ_LOCATION=EU
# Batch BQ writes at end of ingest/score (not per-row during ingest)
BQ_MERGE_ON_INGEST=false
BQ_BATCH_NORMALIZED=true
BQ_BATCH_LLM_SCORES=true
# Place the service account JSON at config/service_account.json (gitignored) or set an absolute path:
GOOGLE_APPLICATION_CREDENTIALS=config/service_account.json
# After credentials work, run once: python main.py init-bq
# Curated employers: shipped CSV used when BigQuery curated_companies is empty
# CURATED_COMPANIES_PATH=registry/curated_companies.csv

# ReliefWeb Jobs API (request appname: https://apidoc.reliefweb.int/parameters#appname)
# Omit or leave empty to skip ReliefWeb until approved; set RELIEFWEB_ENABLED=false to force skip
RELIEFWEB_ENABLED=true
RELIEFWEB_APPNAME=

# Mission job boards (Climatebase, 80k Hours, Escape the City, Tech Jobs for Good, ReliefWeb)
JOB_BOARDS_ENABLED=true
BOARD_INGEST_DELAY_MS=2000
BOARD_DETAIL_DELAY_MS=1500
BOARD_PAUSE_BETWEEN_MS=3000
CLIMATEBASE_MAX_LISTINGS=100
CLIMATEBASE_FETCH_DETAILS=true
BOARD_80000HOURS_MAX_PAGES=3
BOARD_ESCAPETHECITY_MAX_PAGES=3
TJFG_FETCH_DETAILS=true
RELIEFWEB_JOBS_LIMIT=200
# Digest includes all scored unsent jobs when MIN_COMBINED_SCORE=0 (no row cap)
# Webshare proxies (HOST:PORT:USER:PASS per line) — run: python tools/sync_webshare_proxies.py
WEBSHARE_PROXIES_PATH=config/webshare_proxies.txt
WEBSHARE_PROXY_LIST_URL=

# B Corp Typesense API (public search key from frontend bundles)
BCORP_TYPESENSE_API_KEY=
