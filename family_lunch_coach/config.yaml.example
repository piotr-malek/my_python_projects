bigquery:
  project: your-gcp-project-id
  dataset: health_monitoring
  strava_table: activities
  service_account_key_path: config/service_account.json

ollama:
  host: http://localhost:11434
  model: qwen3:14b-q4_K_M

database:
  path: ~/.family_lunch_coach/lunch_coach.db

telegram:
  chat_id: ""

openclaw:
  user_md_path: ~/.openclaw/workspace/USER.md

tunables:
  cook_time_buffer_min: 12
  proactive_discovery_min_distinct_recipes_14d: 4
  shopping_low_coverage_days: 2
  ranking_weights:
    w_gap: 0.35
    w_rating: 0.3
    w_load: 0.25
    w_novelty: 0.1
