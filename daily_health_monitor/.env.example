# --- Google BigQuery ---
BQ_PROJECT_ID=your-gcp-project-id
BQ_DATASET_ID=health_monitoring
BQ_LOCATION=US
GOOGLE_APPLICATION_CREDENTIALS=config/service_account.json

# --- Garmin Connect (unofficial API via garminconnect) ---
GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=your-garmin-password
GARMINTOKENS=~/.garminconnect

# --- Strava API ---
# Create an app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your-client-id
STRAVA_CLIENT_SECRET=your-client-secret
STRAVA_REFRESH_TOKEN=
STRAVA_TOKEN_PATH=~/.health_monitoring/strava_tokens.json
STRAVA_LOOKBACK_DAYS=7

# --- Analytics window ---
# Drives Strava backfill depth and daily analytics lookback
ANALYSIS_DAYS=90

# --- Ollama (local LLM) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:14b-q4_K_M
OLLAMA_NUM_PREDICT=1024
# OLLAMA_NUM_CTX=32768

# --- Email (any SMTP provider; Gmail app password shown as example) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your-smtp-password-or-app-password
EMAIL_TO=you@example.com

# --- Digest schedule (for cron/launchd reference; not enforced by the app) ---
DIGEST_HOUR=7
DIGEST_MINUTE=30

# --- Athlete calibration ---
FTP_WATTS=225
THRESHOLD_HR=170

# --- Local state (logs, token cache, fallback digests) ---
LOCAL_STATE_DIR=~/.health_monitoring

# --- Optional tuning ---
# CTL_FLOOR=30
# STRESS_BAND_MORNING=06:00–09:00
# STRESS_BAND_WORK=09:00–18:00
# STRESS_BAND_EVENING=18:00–22:00
